{
    "name": "aurora/plugin",
    "description": "Attribute-based plugin discovery and management for Aurora CMS",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=8.3",
        "aurora/cache": "^0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Aurora\\Plugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aurora\\Plugin\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable"
}
